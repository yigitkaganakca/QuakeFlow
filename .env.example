
#this is an enbironmtenz template u can use
#
# u should copy this file to `.env` before running:
#     cp .env.example .env
#     docker compose up --build
#
# All credentials below are demo defaults so u should change them for any non-local use.


POSTGRES_USER=quake
POSTGRES_PASSWORD=quake_pw
POSTGRES_DB=quakes
POSTGRES_PORT=5432


AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=airflow_pw
AIRFLOW_PG_DB=airflow


PGADMIN_EMAIL=admin@itu.edu.tr
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050


ES_PORT=9200
KIBANA_PORT=5601
# Heap size, we decided that 512m is enough for the project's data volume on a 16 GB laptop.
ES_JAVA_OPTS=-Xms512m -Xmx512m

#immutable archive
MINIO_ROOT_USER=quake
MINIO_ROOT_PASSWORD=quake_minio_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=quake-raw


NIFI_WEB_HTTP_PORT=8081
# NiFi 1.x lets us disable single-user auth for local academic use.
NIFI_SINGLE_USER_CREDENTIALS_USERNAME=admin
NIFI_SINGLE_USER_CREDENTIALS_PASSWORD=adminadminadmin
# 32+ char passphrase used by NiFi to encrypt sensitive properties (e.g. the
# Postgres password the install_flow script puts on the DBCPConnectionPool).
# Any 32+ chars work; pin it so the encryption stays stable across rebuilds.
NIFI_SENSITIVE_PROPS_KEY=quakeflow-yzv322e-spring-2026-not-a-secret-pinned-locally


AIRFLOW_WEB_PORT=8088
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# we geenerated that once with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_UID=50000

#this is one shot historical run for backfill mode
# Used only when you run:  docker compose --profile backfill up backfill
BACKFILL_MODE=historical          # historical | replay
BACKFILL_DAYS=30                  # window for historical mode
BACKFILL_MIN_MAG=1.0
BACKFILL_SOURCES=AFAD,EMSC,USGS   # KOERI has no official archive API, as far as we researched so it is live only

USER_AGENT=ITU-YZV322E-QuakeFlow/1.0 (academic; contact@itu.edu.tr)
